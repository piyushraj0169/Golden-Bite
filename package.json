{
  "name": "goldenbite-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm explore backend -- npm install && npm explore frontend -- npm install",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "npm run server --prefix backend",
    "start:frontend": "npm run dev --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}